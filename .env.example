# PostgreSQL Connection (e.g. Coolify Dashboard → Database → PostgreSQL → Connection URL)
DATABASE_URL=postgresql://user:password@your-server:5432/cuyemekhane

# Google Analytics
# Get your Measurement ID from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# NextAuth.js (Auth.js)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# Production URL (for Auth.js)
NEXTAUTH_URL=https://your-domain.com

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Callback URL: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Feature Flags
# Toggles the auth system on and off. When set to false, the middleware, SessionProvider, and auth checks are disabled.
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_PROFILE_CUSTOMIZATION_ENABLED=true

# Google SMTP (Favorite Meal Notifications)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Moderator (Comment Reports)
MODERATOR_EMAIL=admin@example.com
# Appoint a user as a moderator by their ID
MODERATOR_USER_ID=your-user-id-here

# APP-URL for Report Notifications
APP_URL=https://example.com

# Cloudflare R2 (Comment Photo Upload)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cukurova-photos
R2_PUBLIC_URL=https://r2-bucket.cukurova.app
NEXT_PUBLIC_PHOTO_UPLOAD_ENABLED=true

# Upstash Redis (Optional)
# If configured, distributed rate limiting is enabled; if not configured, the in-memory fallback is used. Get credentials from: https://console.upstash.com/redis
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token