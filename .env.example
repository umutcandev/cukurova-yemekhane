# ─────────────────────────────────────────────────
# Çukurova Yemekhane — Environment Variables
# ─────────────────────────────────────────────────
# Coolify: Dashboard → Application → Environment Variables
# Lokal:   Bu dosyayı .env.local olarak kopyalayın
# ─────────────────────────────────────────────────

# PostgreSQL Connection (Coolify)
# Coolify Dashboard → Database → PostgreSQL → Connection URL
DATABASE_URL=postgresql://user:password@your-server:5432/cuyemekhane

# Google Analytics
# Get your Measurement ID from: https://analytics.google.com
# NEXT_PUBLIC_ prefix → Build time'da bake edilir!
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# NextAuth.js (Auth.js)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
# Coolify'da production domain'inizi yazın!
NEXTAUTH_URL=https://your-domain.com

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Callback URL'yi de ekleyin: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Feature Flags
# Auth sistemini açıp kapatır. false yapıldığında middleware, SessionProvider
# ve tüm auth API çağrıları devre dışı kalarak Edge Request sayısı düşer.
# NEXT_PUBLIC_ prefix → Build time'da bake edilir!
NEXT_PUBLIC_AUTH_ENABLED=true

# Google SMTP (E-posta Bildirimleri)
# 2FA aktifken App Password oluşturun: Google Hesabı → Güvenlik → Uygulama Şifreleri
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Moderator (Comment Reports)
# Rapor edilen yorumlar bu adrese e-posta olarak gönderilir
MODERATOR_EMAIL=admin@example.com
# Moderatör kullanıcı ID'si (yorum silme yetkisi + rapor e-postası)
MODERATOR_USER_ID=your-user-id-here

# APP-URL for Report Notifications
APP_URL=https://example.com

# Cloudflare R2 (Comment Photo Upload)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cukurova-photos
R2_PUBLIC_URL=https://r2-bucket.cukurova.app
NEXT_PUBLIC_PHOTO_UPLOAD_ENABLED=true

# Upstash Redis (Rate Limiting — Opsiyonel)
# Tanımlanırsa distributed rate limiting aktif olur (Vercel / multi-replica için önerilir).
# Tanımlanmazsa in-memory fallback kullanılır (Coolify single-instance için yeterli).
# Get credentials from: https://console.upstash.com/redis
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token